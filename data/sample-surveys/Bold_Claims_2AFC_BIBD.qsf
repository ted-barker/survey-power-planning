32"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID39"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID38"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID37"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID36"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID35"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID34"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID33"}]},{"Type":"Standard","SubType":"","Description":"Block 5: Branch 5 pairings","ID":"BL_b9O58DL8TBhFgCG","BlockElements":[{"Type":"Question","QuestionID":"QID40"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID47"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID46"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID45"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID44"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID43"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID42"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID41"}]},{"Type":"Standard","SubType":"","Description":"Block 6: Branch 6 pairings","ID":"BL_etlsT30mfyXGL7U","BlockElements":[{"Type":"Question","QuestionID":"QID48"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID55"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID54"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID53"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID52"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID51"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID50"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID49"}]},{"Type":"Standard","SubType":"","Description":"Block 9","ID":"BL_5zEwqtsdJ2WgLhc","BlockElements":[{"Type":"Question","QuestionID":"QID57"}]},{"Type":"Standard","SubType":"","Description":"Block 10","ID":"BL_eXKiYI9sTXvaPjw","BlockElements":[{"Type":"Question","QuestionID":"QID58"}]}]},{"SurveyID":"SV_brBmb2ineWzr1e6","Element":"FL","PrimaryAttribute":"Survey Flow","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"Type":"Root","FlowID":"FL_1","Flow":[{"Type":"EmbeddedData","FlowID":"FL_6","EmbeddedData":[{"Description":"stmt1","Type":"Custom","Field":"stmt1","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"A Wise Account offers the fastest way to send money anywhere in the world. Wise to Wise transfers are almost always instant."},{"Description":"stmt2","Type":"Custom","Field":"stmt2","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Send, spend and get paid in another country without the wait times or hassle of an overseas bank. You can set up a Wise Account without leaving home."},{"Description":"stmt3","Type":"Custom","Field":"stmt3","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"75% of international transfers with a Wise Account are instant. It's the fastest way to send money."},{"Description":"stmt4","Type":"Custom","Field":"stmt4","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Never miss a great rate. A Wise account lets you monitor the market and lock in as soon as you see the rate you want, so you can convert at the best time for you."},{"Description":"stmt5","Type":"Custom","Field":"stmt5","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"The cheapest way to send money internationally is between Wise Accounts. We never charge a fee on Wise to Wise transfers."},{"Description":"stmt6","Type":"Custom","Field":"stmt6","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"If you want to manage money in another currency without the exchange rate fluctuations and transfer fees, get a Wise Account. You can set one up overseas without leaving home."},{"Description":"stmt7","Type":"Custom","Field":"stmt7","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"With a Wise Account, you can use your card to spend abroad just like you do at home, with no exchange rate markups or fees."},{"Description":"stmt8","Type":"Custom","Field":"stmt8","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Switch on Interest with a tap in your Wise Account, and any cash you're holding there gets 4% returns. Why leave money on the table?"},{"Description":"stmt9","Type":"Custom","Field":"stmt9","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"With a Wise Account, premium service is free. Unlike other providers, we don't charge you to open or use an international account, so you can send, spend and withdraw overseas without the extra fees."},{"Description":"stmt10","Type":"Custom","Field":"stmt10","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Open a Wise account in another country, even if you don't live there. Send, receive and spend locally and set up direct debits and payments, with none of the hassle or wait times of an overseas bank."},{"Description":"stmt11","Type":"Custom","Field":"stmt11","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Wise to Wise is the simple way to send and receive money with friends. We make it easy to connect, send a payment link and spend money together seamlessly."},{"Description":"stmt12","Type":"Custom","Field":"stmt12","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Get a Wise Account and you can use the card to spend and withdraw your money at home and abroad. No hidden fees or jacked-up exchange rates, ever."},{"Description":"stmt13","Type":"Custom","Field":"stmt13","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Set up a Wise Account at home and in another country, then you can hold and move your money internationally without the fees and wait times."},{"Description":"stmt14","Type":"Custom","Field":"stmt14","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Don't transfer currency until you're happy with the exchange rate. With a Wise Account, you can set up auto-conversions and we'll only send the money when it's at the rate you wanted."},{"Description":"stmt15","Type":"Custom","Field":"stmt15","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Get a Wise Account and you can turn on Interest instantly, then use your cash like normal whilst it works for you. Grow your money without locking it away."},{"Description":"stmt16","Type":"Custom","Field":"stmt16","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"A Wise Account gives you the international sending and spending you already love from Wise, plus the option to grow and share your money like you do with a bank account."},{"Description":"stmt17","Type":"Custom","Field":"stmt17","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Unlike banks, we never hide our fees or inflate the real market exchange rate. When you use your Wise Account, you'll always see exactly what you're spending before you send."},{"Description":"stmt18","Type":"Custom","Field":"stmt18","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Unlike our competitors, we don't charge you extra fees to use your own money out of hours or at the weekend. The Wise Account works the same way 24\/7."},{"Description":"stmt19","Type":"Custom","Field":"stmt19","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Unlike banks, the Wise Account is designed to work at home and abroad. From your everyday finances to travelling, working or spending in other currencies, it fits the way you use your money."},{"Description":"stmt20","Type":"Custom","Field":"stmt20","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"With the Wise Account, you can hold money and earn returns in the currencies you use most."},{"Description":"stmt21","Type":"Custom","Field":"stmt21","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"At Wise, we're here to safeguard your money, not risk, spend or invest it. It's your money, not ours."},{"Description":"stmt22","Type":"Custom","Field":"stmt22","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Money in a Wise Account is protected by cutting-edge encryption and anti-fraud technology. We run 7 million security checks a day."},{"Description":"stmt23","Type":"Custom","Field":"stmt23","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Our customers trust us to manage and move \u00a3145 billion of their money annually. Open a Wise Account today and see where your money can go."},{"Description":"stmt24","Type":"Custom","Field":"stmt24","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Over 15 million customers trust Wise with their money. Open a Wise Account and see why our adoption rate is growing annually."},{"Description":"stmt25","Type":"Custom","Field":"stmt25","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"Wise Account holdings are growing at 33% a year thanks to millions of new customers. Open a Wise Account and see why they love us."},{"Description":"stmt26","Type":"Custom","Field":"stmt26","VariableType":"String","DataVisibility":[],"AnalyzeText":false,"Value":"15 million customers. One smart Account. Get a Wise Account today and see where we can take your money."},{"Description":"user_id","Type":"Recipient","Field":"user_id","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"email","Type":"Recipient","Field":"email","VariableType":"String","DataVisibility":[],"AnalyzeText":false}]},{"Type":"Block","ID":"BL_82lb1HC2tRCYInA","FlowID":"FL_2","Autofill":[]},{"Type":"Standard","ID":"BL_6VAwYXfRDS6pexU","FlowID":"FL_3","Autofill":[]},{"Type":"Standard","ID":"BL_5zEwqtsdJ2WgLhc","FlowID":"FL_38","Autofill":[]},{"Type":"Branch","FlowID":"FL_43","Description":"New Branch","BranchLogic":{"0":{"0":{"LogicType":"Question","QuestionID":"QID57","Question